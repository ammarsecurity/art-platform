# انسخ إلى .env بجانب docker-compose.yml:
#   cp env.example .env

# MySQL (نفس السيرفر أو خارجي)
DB_CONNECTION=Server=172.17.0.1;Database=art_platform;User=root;Password=SECRET;CharSet=utf8mb4;

# JWT — استخدم مفتاحاً عشوائياً طويلاً (32 حرفاً فأكثر)
JWT_KEY=YourSuperSecretKeyThatIsAtLeast32CharactersLong!

JWT_ISSUER=ArtPlatform
JWT_AUDIENCE=ArtPlatformUsers

# الرابط العام للـ API (يُستخدم في روابط الوسائط)
API_PUBLIC_BASE_URL=https://api.murtada-thamer.com

# واجهات مسموح بها للمتصفح (مفصولة بفواصل بدون مسافات زائدة)
CORS_ORIGINS=https://murtada-thamer.com,https://www.murtada-thamer.com,http://localhost:4435
